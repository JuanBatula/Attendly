<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".SubjectsFragment">

    <TextView
        android:id="@+id/title_subjects"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="My Subjects"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_container"
        android:layout_below="@id/title_subjects"
        android:layout_marginTop="10dp"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <RelativeLayout
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/icon_n"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:background="#E8F5E9"
                        android:gravity="center"
                        android:text="N"
                        android:textColor="@color/networking_green"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/icon_n"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Networking 2"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="16sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IT228"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="end"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85%"
                            android:textColor="@color/teal_attendance"
                            android:textStyle="bold"
                            android:textSize="16sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ATTENDANCE"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/icon_n"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <Button android:layout_width="80dp" android:layout_height="35dp" android:text="Edit" android:textSize="10sp" android:textAllCaps="false" android:backgroundTint="#F5F5F5" android:textColor="#000000" android:layout_marginEnd="8dp"/>
                        <Button android:layout_width="80dp" android:layout_height="35dp" android:text="Delete" android:textSize="10sp" android:textAllCaps="false" android:backgroundTint="#FFEBEE" android:textColor="#E74C3C"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <RelativeLayout
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/icon_o"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:background="#FFF3E0"
                        android:gravity="center"
                        android:text="O"
                        android:textColor="@color/oop_orange"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/icon_o"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OOP2"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="16sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CSIT228"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="end"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="67%"
                            android:textColor="@color/teal_attendance"
                            android:textStyle="bold"
                            android:textSize="16sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ATTENDANCE"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/icon_o"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <Button android:layout_width="80dp" android:layout_height="35dp" android:text="Edit" android:textSize="10sp" android:textAllCaps="false" android:backgroundTint="#F5F5F5" android:textColor="#000000" android:layout_marginEnd="8dp"/>
                        <Button android:layout_width="80dp" android:layout_height="35dp" android:text="Delete" android:textSize="10sp" android:textAllCaps="false" android:backgroundTint="#FFEBEE" android:textColor="#E74C3C"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <RelativeLayout
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/icon_p"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:background="#FFEBEE"
                        android:gravity="center"
                        android:text="P"
                        android:textColor="@color/pe_red"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/icon_p"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PE"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="16sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PE206"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="end"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45%"
                            android:textColor="@color/teal_attendance"
                            android:textStyle="bold"
                            android:textSize="16sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ATTENDANCE"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/icon_p"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <Button android:layout_width="80dp" android:layout_height="35dp" android:text="Edit" android:textSize="10sp" android:textAllCaps="false" android:backgroundTint="#F5F5F5" android:textColor="#000000" android:layout_marginEnd="8dp"/>
                        <Button android:layout_width="80dp" android:layout_height="35dp" android:text="Delete" android:textSize="10sp" android:textAllCaps="false" android:backgroundTint="#FFEBEE" android:textColor="#E74C3C"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FFFFFF">

        <Button
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:backgroundTint="@color/teal_attendance"
            android:text="+ Add Subject"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="18sp"
            app:cornerRadius="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="15dp"
            android:text="Cancel"
            android:textColor="#9E9E9E"
            android:textSize="16sp" />
    </LinearLayout>

</RelativeLayout>